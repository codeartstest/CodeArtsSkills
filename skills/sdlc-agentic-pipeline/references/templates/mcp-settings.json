{
  "_conditional_generation": {
    "_doc": "This is a REFERENCE template showing all possible MCP entries. During onboarding, the generation logic reads .codeartsdoer/tool-selections.json and includes ONLY entries for selected MCP items. Unselected entries are omitted entirely. If NO MCP servers are selected, write {\"mcpServers\": {}}.",
    "selectionMapping": {
      "atlassian-rovo-mcp": "jira (item 2)",
      "github": "github (item 1)",
      "sonarqube": "sonarcloud (item 3)",
      "semgrep": "semgrep (item 4)",
      "terraform": "huawei-ecs (item 6, Option B only)"
    }
  },
  "mcpServers": {
    "atlassian-rovo-mcp": {
      "url": "https://mcp.atlassian.com/v1/mcp",
      "headers": {
        "Authorization": "Basic <JIRA_MCP_AUTH_BASE64>"
      }
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer <GITHUB_PAT>"
      }
    },
    "sonarqube": {
      "url": "https://api.sonarcloud.io/mcp",
      "headers": {
        "Authorization": "Bearer <SONAR_TOKEN>",
        "SONARQUBE_ORG": "<SONAR_ORGANIZATION>"
      }
    },
    "semgrep": {
      "command": "<SEMGREP_EXECUTABLE_PATH>",
      "args": ["mcp"],
      "env": {
        "SEMGREP_APP_TOKEN": "<SEMGREP_APP_TOKEN>",
        "PYTHONIOENCODING": "utf-8"
      },
      "disabled": false,
      "timeout": 120000
    },
    "terraform": {
      "command": "<TERRAFORM_MCP_SERVER_PATH>",
      "args": ["stdio"],
      "disabled": false,
      "timeout": 120000
    }
  }
}