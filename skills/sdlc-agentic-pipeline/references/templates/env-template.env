# =============================================================================
# CONDITIONAL GENERATION:
# This is a REFERENCE template showing all possible env var blocks. During
# onboarding, the generation logic reads .codeartsdoer/tool-selections.json
# and includes ONLY blocks for selected services. Unselected blocks are
# omitted entirely. See multi-tool-selection-plan.md §6.2.
# =============================================================================

# --- CONDITIONAL: Jira (item 2, `jira`) - include only if selected ---
# Jira MCP
JIRA_CLOUD_ID=<JIRA_CLOUD_ID>
JIRA_EMAIL=<JIRA_EMAIL>
JIRA_API_TOKEN=<JIRA_API_TOKEN>
JIRA_PROJECT_KEY=<JIRA_PROJECT_KEY>

# --- CONDITIONAL: SonarCloud (item 3, `sonarcloud`) - include only if selected ---
# SonarCloud MCP
SONAR_PROJECT_KEY=<SONAR_PROJECT_KEY>
SONAR_ORGANIZATION=<SONAR_ORGANIZATION>
SONAR_TOKEN=<SONAR_TOKEN>

# --- CONDITIONAL: Semgrep (item 4, `semgrep`) - include only if selected ---
# Semgrep MCP
SEMGREP_APP_TOKEN=<SEMGREP_APP_TOKEN>

# --- CONDITIONAL: JFrog Artifactory (item 5, `jfrog`) - include only if selected ---
# JFrog Artifactory
# Tip: Copy platform URL from browser address bar when logged in (e.g., https://demoartifacthw.jfrog.io/)
JFROG_PLATFORM_URL=<JFROG_PLATFORM_URL>
# Tip: Docker registry hostname (e.g., demoartifacthw.jfrog.io). WARNING: No underscores in repo name (DNS limitation).
JFROG_DOCKER_REGISTRY=<JFROG_DOCKER_REGISTRY>
# Tip: Repository key created in JFrog UI (Administration > Repositories). Use hyphens, not underscores.
JFROG_REPO_KEY=<JFROG_REPO_KEY>
# Tip: The email address used to log in to JFrog (e.g., user@email.com)
JFROG_USERNAME=<JFROG_USERNAME>
# Tip: Generate via Administration > User Management > Access Tokens > Generate Token
JFROG_PASSWORD=<JFROG_PASSWORD>
# Tip: Find via Administration > All Projects > Project Key column
JFROG_PROJECT=<JFROG_PROJECT>

# --- CONDITIONAL: Huawei Cloud ECS (item 6, `huawei-ecs`) - include only if selected ---
# Huawei Cloud ECS Deployment
HUAWEI_ECS_HOST=<HUAWEI_ECS_HOST>
HUAWEI_ECS_USER=<HUAWEI_ECS_USER>
HUAWEI_ECS_SSH_KEY_PATH=<HUAWEI_ECS_SSH_KEY_PATH>
HUAWEI_ECS_APP_DIR=/app
HUAWEI_ECS_DOCKER_REGISTRY=<HUAWEI_ECS_DOCKER_REGISTRY>

# --- CONDITIONAL: GitHub (item 1, `github`) - include only if selected ---
# GitHub Repository
GITHUB_OWNER=<GITHUB_OWNER>
GITHUB_REPO=<GITHUB_REPO>